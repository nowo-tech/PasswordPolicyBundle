###> symfony/framework-bundle ###
# APP_ENV: Symfony environment. Use `dev` for local development.
APP_ENV=dev
# APP_SECRET: Local secret used by Symfony for tokens/signing.
APP_SECRET=change_this_secret_key_to_a_random_value
# APP_DEBUG: Enable debug mode in development.
APP_DEBUG=1
###< symfony/framework-bundle ###

###> symfony/runtime ###
# APP_RUNTIME: Symfony runtime class used by the application.
APP_RUNTIME=Symfony\\Runtime\\SymfonyRuntime
###< symfony/runtime ###

# Demo HTTP port published by Docker (host -> container :80).
PORT=8001
# Default URI for this demo.
DEFAULT_URI=http://localhost:8001

# Xdebug settings (optional):
# - Set XDEBUG_MODE=debug for step debugging.
# - Keep XDEBUG_MODE=develop for dev helpers only.
# - Your IDE should listen on XDEBUG_CLIENT_PORT.
# XDEBUG_MODE=develop
# XDEBUG_MODE=debug
# XDEBUG_CLIENT_HOST=host.docker.internal
# XDEBUG_CLIENT_PORT=9003

# MySQL credentials used by the demo containers.
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=password_policy_demo
MYSQL_USER=demo_user
MYSQL_PASSWORD=demo_password

###> doctrine/doctrine-bundle ###
# DATABASE_URL: Doctrine connection string using the Docker service host (`mysql`).
DATABASE_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###
