# PHPStan configuration for Password Policy Bundle
# Compatible with PHP 8.1+ and Symfony 6.x / 7.x / 8.x
# Extensions (phpstan-symfony, phpstan-phpunit, phpstan-mockery) are auto-included via phpstan/extension-installer.

parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - demo/*
